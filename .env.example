GINGR_API_KEY=
GINGR_WEBHOOK_SIGNATURE_KEY=
GINGR_LOCATION_ID=1
GINGR_TYPE_IDS=
GINGR_SYNC_SECRET=

# Admin auth — prefer ADMIN_PASSWORD_HASH in production (generate: npx tsx scripts/hash-admin-password.ts your-password)
# Username "admin" aliases to Lonnie Sandoval (lonnie@fitdog.com) Super Admin.
ADMIN_USERNAME=lonnie@fitdog.com
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

LOBBY_DISPLAY_TOKEN=
# Optional. Embeds ?token= in lobby cast URLs. Lobby board reads stay open so any staff member can cast.
NEXT_PUBLIC_GOOGLE_CAST_APP_ID=

# Shelly Plug US Gen4 alert light — server-only (never expose SHELLY_AUTH_KEY to the browser)
SHELLY_ALERT_ENABLED=false
SHELLY_CLOUD_HOST=https://shelly-267-eu.shelly.cloud
SHELLY_AUTH_KEY=
SHELLY_DEVICE_ID=
SHELLY_CHANNEL=0
SHELLY_MIN_SECONDS_BETWEEN_ALERTS=2
# Push notice alert light duration in seconds (default 300 = 5 minutes)
SHELLY_PUSH_NOTICE_DURATION_SECONDS=300
LOBBY_CHECKOUT_DISPLAY_MINUTES=10
NEXT_PUBLIC_SITE_URL=https://staff.ruffops.com
CRON_SECRET=

# HR Consult — Gemini (server-only; never expose to the browser)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
