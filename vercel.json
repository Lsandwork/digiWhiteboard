{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-reminders",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/walk-board-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/cast-display-schedule",
      "schedule": "*/15 * * * *"
    }
  ]
}
